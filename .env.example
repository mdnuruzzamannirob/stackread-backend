NODE_ENV=development
PORT=5000
API_VERSION=v1
MONGODB_URI=mongodb://127.0.0.1:27017/library-management-system
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info
LOG_DIR=logs
LOG_ROTATE_MAX_SIZE=20m
LOG_ROTATE_APP_MAX_FILES=14d
LOG_ROTATE_ERROR_MAX_FILES=30d
LOG_ZIPPED_ARCHIVE=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_MAX=120
SEARCH_RATE_LIMIT_MAX=180
WEBHOOK_RATE_LIMIT_MAX=1000
REPORT_RATE_LIMIT_MAX=80
JWT_USER_SECRET=change-this-user-secret
JWT_STAFF_SECRET=change-this-staff-secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_ISSUER=lms-backend
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback
TWO_FACTOR_ISSUER=LMS-Staff
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
RESEND_API_KEY=
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
PUSH_PROVIDER=console
FCM_SERVER_KEY=
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=uploads
LOCAL_STORAGE_BASE_URL=http://localhost:5000/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PAYMENT_PROVIDER=sslcommerz
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-this-password
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=30000
JOB_RETRY_LIMIT=3
JOB_RETRY_BACKOFF_MS=500
SHUTDOWN_TIMEOUT_MS=20000
