# Runtime
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/library-management-system
# Optional: set custom DNS resolvers when SRV lookup fails (e.g. ECONNREFUSED)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# HTTP
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_DIR=logs
LOG_ROTATE_MAX_SIZE=20m
LOG_ROTATE_APP_MAX_FILES=14d
LOG_ROTATE_ERROR_MAX_FILES=30d
LOG_ZIPPED_ARCHIVE=true

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_MAX=120
SEARCH_RATE_LIMIT_MAX=180
WEBHOOK_RATE_LIMIT_MAX=1000
REPORT_RATE_LIMIT_MAX=80

# JWT
JWT_USER_SECRET=change-this-user-secret
JWT_STAFF_SECRET=change-this-staff-secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
TEMP_TOKEN_EXPIRES_IN=5m
STAFF_SETUP_TOKEN_EXPIRES_IN=10m
JWT_ISSUER=lms-backend
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=change-this-session-secret

# OAuth + 2FA
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback
TWO_FACTOR_ISSUER=LMS-Staff

# Email (Gmail SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=noreply@example.com

# Push (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
STAFF_PORTAL_URL=http://localhost:3001

# Super admin
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-this-password

# Worker
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=30000
JOB_RETRY_LIMIT=3
JOB_RETRY_BACKOFF_MS=500
SHUTDOWN_TIMEOUT_MS=20000

# Domain defaults
REPORT_DOWNLOAD_TTL_DAYS=7
DEFAULT_TIMEZONE=Asia/Dhaka
DEFAULT_CURRENCY=BDT
DEFAULT_LANGUAGE=en
