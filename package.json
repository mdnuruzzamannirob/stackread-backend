{
  "name": "library-management-system-backend",
  "version": "1.0.0",
  "description": "Library Management System Backend — Node.js + Express + TypeScript + MongoDB",
  "main": "dist/app/server.js",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "dev:worker": "tsx watch src/app/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "start:worker": "node dist/app/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "seed:permissions": "tsx src/seeds/permissions.seed.ts",
    "seed:plans": "tsx src/seeds/plans.seed.ts",
    "seed:settings": "tsx src/seeds/settings.seed.ts",
    "seed:super-admin": "tsx src/seeds/superAdmin.seed.ts",
    "seed:all": "tsx src/seeds/all.seed.ts",
    "seed": "tsx src/scripts/seed.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "export:openapi": "echo OpenAPI export available at documentation/OpenAPI_v1.json",
    "export:postman": "echo Postman export available at documentation/Postman_Collection_v1.json"
  },
  "keywords": [],
  "author": "Md. Nuruzzaman",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "speakeasy": "^2.0.0",
    "sslcommerz-lts": "^1.2.0",
    "stripe": "^20.4.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.0",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
